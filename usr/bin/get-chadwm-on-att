#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }

packages=(
    alacritty
    archlinux-logout-git
    arconet-variety-config
    arcolinux-chadwm-git
    arcolinux-chadwm-pacman-hook-git
    arcolinux-powermenu-git
    dash
    dmenu
    eww
    feh
    lxappearance
    picom
    polkit-gnome
    rofi-lbonn-wayland
    scrot
    sxhkd
    thunar
    thunar-archive-plugin
    thunar-volman
    ttf-hack
    ttf-jetbrains-mono-nerd
    ttf-meslo-nerd-font-powerlevel10k
    volumeicon
    xfce4-notifyd
    xfce4-power-manager
    xfce4-screenshooter
    xfce4-settings
    xfce4-taskmanager
    xfce4-terminal
)

install_package() {
    if pacman -Qi "$1" &>/dev/null; then
        info "Already installed: $1"
    else
        info "Installing: $1"
        sudo pacman -S --noconfirm --needed "$1"
        success "$1 installed"
    fi
}

header "Remove conflicting rofi packages"
for pkg in rofi rofi-lbonn-wayland-git rofi-lbonn-wayland-only-git; do
    if pacman -Qi "$pkg" &>/dev/null; then
        info "Removing $pkg"
        sudo pacman -Rdd --noconfirm "$pkg"
        success "$pkg removed"
    else
        info "$pkg not installed — skipping"
    fi
done

header "Install chadwm packages"
count=0
for name in "${packages[@]}"; do
    count=$((count + 1))
    info "Package $count/${#packages[@]}: $name"
    install_package "$name"
done
success "All chadwm packages processed"

header "Back up existing config and apply skel"
backup_dir="$HOME/.config-backup-$(date +%Y.%m.%d-%H.%M.%S)"
info "Backing up ~/.config to $backup_dir"
cp -Rf "$HOME/.config" "$backup_dir"
success "Backup created at $backup_dir"

info "Copying /etc/skel to home"
cp -arf /etc/skel/. "$HOME"
success "Skel applied"

header "Done"
success "chadwm installation complete"

read -rp "Press Enter to close..."

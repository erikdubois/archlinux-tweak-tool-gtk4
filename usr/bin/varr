#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo ""; echo "${CYAN}################################################################################${RESET}"; echo ""; }
header()  { echo ""; echo "${CYAN}################################################################################${RESET}"; echo "  $1"; echo "${CYAN}################################################################################${RESET}"; echo ""; }
success() { echo "${GREEN}[SUCCESS] $1${RESET}"; }
info()    { echo "${CYAN}[INFO]    $1${RESET}"; }
warn()    { echo "${YELLOW}[WARN]    $1${RESET}"; }
error()   { echo "${RED}[ERROR]   $1${RESET}"; }

Online=0

check_connectivity() {
    local test_ip="8.8.8.8"
    local test_count=1

    if ping -c "${test_count}" "${test_ip}" > /dev/null 2>&1; then
        info "Internet connectivity confirmed"
        Online=1
    else
        warn "No internet connectivity detected"
        Online=0
    fi
}

header "Reinstalling default variety config from Nemesis"

check_connectivity

if [ "${Online}" -eq 1 ]; then
    header "Downloading latest variety config from GitHub"
    sudo wget https://raw.githubusercontent.com/erikdubois/arcolinux-nemesis/master/Personal/settings/variety/variety.conf \
        -O ~/.config/variety/variety.conf
    success "Nemesis variety config is in place"
else
    error "No internet — variety config was not updated"
fi

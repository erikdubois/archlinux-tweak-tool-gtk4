#!/bin/bash
set -euo pipefail

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"; }
header()    { separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  ✔ $*${RESET}"; }
info()      { echo "    $*"; }
warn()      { echo "${YELLOW}  ⚠ $*${RESET}"; }
error()     { echo "${RED}  ✘ $*${RESET}"; }

# Resolve the real user's home (works whether run as root via sudo or directly)
REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)

# Every -bak and .bak variant of files ATT creates — derived from functions_backup.py + services.py
ATT_BACKUPS=(
    "/etc/hosts-bak"
    "/etc/hosts.bak"
    "/etc/nsswitch.conf-bak"
    "/etc/nsswitch.conf.bak"
    "/etc/pacman.d/mirrorlist-bak"
    "/etc/pacman.d/mirrorlist.bak"
    "/etc/samba/smb.conf-bak"
    "/etc/samba/smb.conf.bak"
    "/usr/share/icons/default/index.theme-bak"
    "/usr/share/icons/default/index.theme.bak"
    "${REAL_HOME}/.bashrc-bak"
    "${REAL_HOME}/.bashrc.bak"
    "${REAL_HOME}/.zshrc-bak"
    "${REAL_HOME}/.zshrc.bak"
    "${REAL_HOME}/.config/fish/config.fish-bak"
    "${REAL_HOME}/.config/fish/config.fish.bak"
    "${REAL_HOME}/.config/fastfetch/config.jsonc-bak"
    "${REAL_HOME}/.config/fastfetch/config.jsonc.bak"
)

header "Remove ATT backup files"

found=()
for f in "${ATT_BACKUPS[@]}"; do
    [[ -e "$f" ]] && found+=("$f")
done

if [[ ${#found[@]} -eq 0 ]]; then
    warn "No ATT backup files found."
    exit 0
fi

info "Found ${#found[@]} backup file(s):"
echo
for f in "${found[@]}"; do
    info "  $f"
done
echo

read -r -p "    Delete all of the above? [y/N] " confirm
echo

if [[ "${confirm,,}" != "y" ]]; then
    warn "Aborted — nothing deleted."
    exit 0
fi

header "Deleting"

deleted=0
failed=0

for f in "${found[@]}"; do
    if rm -f -- "$f"; then
        success "Deleted: $f"
        (( deleted++ )) || true
    else
        error "Failed:  $f"
        (( failed++ )) || true
    fi
done

separator
success "Done — $deleted deleted, $failed failed."

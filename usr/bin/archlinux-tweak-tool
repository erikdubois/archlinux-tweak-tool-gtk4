#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }

# ── Guard: not root ────────────────────────────────────────────────────────────
header "Checking Environment"

if [[ $(whoami) == "root" ]]; then
    error "Do not run this script as root."
    exit 1
fi

if [[ -z "${DISPLAY:-}" ]]; then
    error "DISPLAY variable is not set."
    exit 1
fi

# ── Detect session ─────────────────────────────────────────────────────────────
SESSION=$(loginctl show-session "$(loginctl | grep "$(whoami)" | awk '{print $1}')" -p Type \
    | awk -F= '{print $2}' | grep "x11\|wayland\|tty" || true)

if [[ -z "$SESSION" ]]; then
    error "Failed to verify session for user — SESSION is empty"
    exit 1
fi

# ── Xauth setup ────────────────────────────────────────────────────────────────
XAUTHORITY=$(xauth info | awk -F"Authority file:" '{print $2}' | tr -d ' ' || true)

if [[ -z "$XAUTHORITY" ]]; then
    error "XAUTHORITY file is not set."
    exit 1
fi

[[ -s "$XAUTHORITY" ]] || touch "$XAUTHORITY"

XAUTH_HONORED=$(xauth info | awk -F"Changes honored:" '{print $2}' | tr -d ' ' || true)
if [[ "$XAUTH_HONORED" != "yes" ]]; then
    warn "Xauth changes honored = no — restart X server if issues occur"
fi

info "XAUTHORITY       = $XAUTHORITY"
info "DBUS_SESSION_BUS = ${DBUS_SESSION_BUS_ADDRESS:-not set}"
info "DESKTOP_SESSION  = ${DESKTOP_SESSION:-not set}"

# ── Launch helpers ─────────────────────────────────────────────────────────────
start_in_wayland() {
    info "Starting in Wayland session"
    xauth gen "$DISPLAY" &>/dev/null || true
    pkexec '/usr/share/archlinux-tweak-tool/archlinux-tweak-tool.py'
}

start_in_x11() {
    info "Starting in X11 session"
    pkexec '/usr/share/archlinux-tweak-tool/archlinux-tweak-tool.py'
}

start_in_tty() {
    info "Starting in TTY session"
    pkexec '/usr/share/archlinux-tweak-tool/archlinux-tweak-tool.py'
}

# ── Launch ─────────────────────────────────────────────────────────────────────
header "Launching ATT — Session: $SESSION / Display: ${DISPLAY:-not set}"

case "$SESSION" in
    wayland)
        start_in_wayland
        ;;
    x11)
        start_in_x11
        ;;
    tty)
        start_in_tty
        ;;
    *)
        warn "Session could not be verified — falling back to XDG_SESSION_TYPE"
        case "${XDG_SESSION_TYPE:-}" in
            wayland) start_in_wayland ;;
            tty)     start_in_tty ;;
            x11)     start_in_x11 ;;
            *)
                error "${XDG_SESSION_TYPE:-XDG_SESSION_TYPE} is empty — cannot continue"
                exit 1
                ;;
        esac
        ;;
esac

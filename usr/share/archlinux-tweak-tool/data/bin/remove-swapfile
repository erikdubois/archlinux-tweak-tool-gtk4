#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }

SWAPFILE=/swapfile

header "Remove Swapfile"
info "Target: $SWAPFILE"

if [[ ! -f "$SWAPFILE" ]]; then
    warn "No swapfile found at $SWAPFILE — nothing to do"
    read -rp "Press Enter to close..."
    exit 0
fi

# ── Disable swapfile ──────────────────────────────────────────────────────────
header "Disabling Swapfile"
if swapon --show | grep -q "$SWAPFILE"; then
    info "Disabling $SWAPFILE..."
    swapoff "$SWAPFILE"
    success "Swapfile disabled"
else
    info "Swapfile not currently active"
fi

# ── Remove from fstab ─────────────────────────────────────────────────────────
header "Updating /etc/fstab"
info "Removing $SWAPFILE entry from /etc/fstab..."
sed -i "\|$SWAPFILE|d" /etc/fstab
success "fstab updated"

# ── Delete swapfile ───────────────────────────────────────────────────────────
header "Deleting Swapfile"
info "Removing $SWAPFILE..."
rm -f "$SWAPFILE"
success "Swapfile deleted"

# ── Summary ───────────────────────────────────────────────────────────────────
header "Active Swap Devices"
swapon --show
success "Swapfile removed successfully"

read -rp "Press Enter to close..."

#!/bin/bash
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)

KEYRING=$(find /usr/share/archlinux-tweak-tool/data/chaotic/keyring -name "chaotic-keyring-*.pkg.tar.zst" | head -1)
MIRRORLIST=$(find /usr/share/archlinux-tweak-tool/data/chaotic/mirrorlist -name "chaotic-mirrorlist-*.pkg.tar.zst" | head -1)

if [[ -z "$KEYRING" || -z "$MIRRORLIST" ]]; then
    error "Package file not found in data/chaotic/ — cannot install"
    read -p "Press enter to close"
    exit 1
fi

separator() { echo "${CYAN}===============================================================================${RESET}"; }
header()    { echo ""; separator; echo "${CYAN}  $1${RESET}"; separator; }
success()   { echo "${GREEN}  ✓ $1${RESET}"; }
error()     { echo "${RED}  ✗ $1${RESET}"; }

header "Chaotic-AUR Setup"

header "Importing Signing Key"
pacman-key --recv-key 3056513887B78AEB --keyserver keyserver.ubuntu.com
pacman-key --lsign-key 3056513887B78AEB
success "Signing key imported"

header "Installing chaotic-keyring and chaotic-mirrorlist"
pacman -U --noconfirm "$KEYRING" "$MIRRORLIST"
success "Chaotic-AUR setup complete"

separator
echo "${GREEN}  DONE — you can close this window${RESET}"
separator
echo ""
read -p "Press enter to close"

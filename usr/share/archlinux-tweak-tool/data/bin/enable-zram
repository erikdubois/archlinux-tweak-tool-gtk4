#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }

SIZE=${1:-"ram / 2"}
ZRAM_CONF=/etc/systemd/zram-generator.conf

header "Enable zram"
info "zram size: $SIZE"

# ── Install zram-generator if missing ─────────────────────────────────────────
header "Checking zram-generator"
if ! pacman -Qi zram-generator &>/dev/null; then
    info "zram-generator not installed — installing..."
    pacman -S zram-generator --noconfirm --needed
    success "zram-generator installed"
else
    info "zram-generator already installed"
fi

# ── Write config ──────────────────────────────────────────────────────────────
header "Writing zram Configuration"
info "Target: $ZRAM_CONF"
cat > "$ZRAM_CONF" << EOF
[zram0]
zram-size = $SIZE
compression-algorithm = zstd
EOF
success "Config written"

# ── Reload and start ──────────────────────────────────────────────────────────
header "Starting zram"
info "Reloading systemd daemon..."
systemctl daemon-reload
info "Starting systemd-zram-setup@zram0.service..."
systemctl start systemd-zram-setup@zram0.service
success "zram started"

# ── Summary ───────────────────────────────────────────────────────────────────
header "Active Swap Devices"
swapon --show
info "Config contents:"
cat "$ZRAM_CONF"
success "zram enabled successfully"

read -rp "Press Enter to close..."

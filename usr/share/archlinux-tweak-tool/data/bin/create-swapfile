#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }

SIZE=${1:-2G}
SWAPFILE=/swapfile

parse_size_mb() {
    local s="${1^^}"
    local num="${s//[^0-9]/}"
    local unit="${s//[0-9]/}"
    case "$unit" in
        G) echo $(( num * 1024 )) ;;
        M) echo "$num" ;;
        K) echo $(( num / 1024 )) ;;
        *) echo $(( num / 1024 / 1024 )) ;;
    esac
}

header "Create Swapfile"
FSTYPE=$(findmnt -n -o FSTYPE /)
info "Swapfile  : $SWAPFILE"
info "Size      : $SIZE"
info "Filesystem: $FSTYPE"

if [[ "$FSTYPE" != "ext4" && "$FSTYPE" != "btrfs" ]]; then
    error "Unsupported filesystem: $FSTYPE"
    error "Only ext4 and btrfs are supported"
    read -rp "Press Enter to close..."
    exit 1
fi

# ── Disable and remove existing swapfile ──────────────────────────────────────
header "Checking for Existing Swapfile"
if swapon --show | grep -q "$SWAPFILE"; then
    warn "Active swapfile found — disabling..."
    swapoff "$SWAPFILE"
    success "Swapfile disabled"
fi
if [[ -f "$SWAPFILE" ]]; then
    warn "Old swapfile found — removing..."
    rm -f "$SWAPFILE"
    success "Old swapfile removed"
else
    info "No existing swapfile — proceeding"
fi

# ── Create swapfile ───────────────────────────────────────────────────────────
header "Writing Swapfile ($SIZE)"
MB=$(parse_size_mb "$SIZE")

if [[ "$FSTYPE" = "btrfs" ]]; then
    info "btrfs detected — disabling Copy-on-Write before writing"
    touch "$SWAPFILE"
    chattr +C "$SWAPFILE"
fi

dd if=/dev/zero of="$SWAPFILE" bs=1M count="$MB" status=progress
echo
success "Swapfile written"

# ── Configure swapfile ────────────────────────────────────────────────────────
header "Configuring Swapfile"
info "Setting permissions (chmod 600)..."
chmod 600 "$SWAPFILE"
info "Formatting as swap..."
mkswap "$SWAPFILE"
info "Activating swapfile..."
swapon "$SWAPFILE"
success "Swapfile active"

if ! grep -q "$SWAPFILE" /etc/fstab; then
    info "Adding $SWAPFILE to /etc/fstab..."
    echo "$SWAPFILE none swap defaults 0 0" >> /etc/fstab
    success "fstab updated"
else
    warn "$SWAPFILE already in /etc/fstab — skipping"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
header "Active Swap Devices"
swapon --show
success "Swapfile created successfully"

read -rp "Press Enter to close..."
